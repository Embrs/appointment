# =============================================================================
# 預約平台開發環境變數（.env.dev）
# 由 npm run dev 自動載入（nuxt dev --dotenv .env.dev）
# 注意：本檔有入庫（.gitignore 中 !.env.dev），勿放真實密碼
# =============================================================================

# ----- Nuxt -----
NUXT_API_BASE=http://localhost
NUXT_PUBLIC_TEST_MODE=F
NUXT_PUBLIC_GTM_ID=
NUXT_PUBLIC_CLARITY_CODE=

# ----- 資料庫 -----
# Railway 託管 PostgreSQL（dev / staging 共用）
DATABASE_URL=postgresql://postgres:WVNJgXvhnGFzAiRFiooqzWyZvNGQPcDJ@switchback.proxy.rlwy.net:11029/railway

# ----- JWT -----
# 開發用 placeholder；上線必須用 openssl rand -hex 32 產生強 secret
JWT_SECRET=dev_jwt_secret_change_me_in_production

# ----- Cloudflare R2（S3 相容）-----
R2_ACCOUNT_ID=df0eedc3c474473ca11724056f594376
R2_ACCESS_KEY_ID=8287413b1b05ac6ccc1478c6a72a9374
R2_SECRET_ACCESS_KEY=a68ac576f9bcfafa2f387a7c8e03ce5e664ac4cd4f1842cc015833bf554467b7
R2_BUCKET_NAME=appointment

# ----- Cron 觸發密鑰 -----
# 外部 cron service 觸發 /api/cron/* 時帶 x-cron-secret header
CRON_SECRET=dev_cron_secret_change_me
