# =============================================================================
# 預約平台環境變數範本（.env.example）
# 用法：複製為 .env / .env.dev 並填入實際值
# Railway 部署時，請在 Railway dashboard 設定相同變數
# =============================================================================

# ----- Nuxt -----
# API base URL；瀏覽器端與 server-side 共用
# 範例（本機）：http://localhost
# 範例（生產）：https://book.example.com
NUXT_API_BASE=

# 測試模式開關（T = 啟用 mock 資料；F = 真實 API）
NUXT_PUBLIC_TEST_MODE=F

# Google Tag Manager ID（選填，留空不載入 GTM）
NUXT_PUBLIC_GTM_ID=

# Microsoft Clarity 追蹤碼（選填，留空不載入）
NUXT_PUBLIC_CLARITY_CODE=

# ----- 資料庫 -----
# PostgreSQL 連線字串（Railway 自動注入到 production）
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# ----- JWT 認證 -----
# 簽署 JWT 的密鑰，必須夠強且保密
# 產生方式：openssl rand -hex 32
# 上線必須更換，勿沿用開發值
JWT_SECRET=

# ----- Cloudflare R2（S3 相容物件儲存）-----
# Cloudflare account ID（dashboard 右側）
R2_ACCOUNT_ID=

# R2 API token access key
R2_ACCESS_KEY_ID=

# R2 API token secret key
R2_SECRET_ACCESS_KEY=

# R2 bucket 名稱（公開讀取，需在 dashboard 設定 public access）
R2_BUCKET_NAME=

# R2 自訂域名（選填，留空使用預設 r2.cloudflarestorage.com）
# 範例：https://cdn.example.com
R2_PUBLIC_BASE_URL=

# ----- 排程 cron 觸發密鑰 -----
# 外部 cron service（cron-job.org / Upstash QStash）呼叫
# /nuxt-api/cron/* 時需帶 x-cron-secret header
# 產生方式：openssl rand -hex 32
CRON_SECRET=
